#!/usr/bin/env python3
"""soc-transcript [role] [-f] [--thinking] [--session UUID] [--list]

Pretty-print a SOC role's Claude Code run transcript -- the full chat log
(user/assistant messages, tool calls + results, optionally thinking) that
Claude Code writes under the role's HOME while it runs.

The transcript files are role-owned mode 600, so this must run as root:
    sudo soc-transcript analyst              # newest run, full replay
    sudo soc-transcript analyst -f           # follow live while it runs
    sudo soc-transcript analyst --thinking   # include the model's reasoning
    sudo soc-transcript specialist --session <uuid>
    sudo soc-transcript --list               # list sessions for every role
    sudo soc-transcript analyst --list       # list just analyst's sessions

-f watches the role's session dir and tails the newest transcript, switching
when a new session starts (the analyst two-pass opens a fresh session for the
Sonnet stage, so a live follow rolls over to it automatically).

--list is how you find the UUID to hand to --session: it prints each
session's id, start/end time, turn count, and a preview (the model's last
text message -- for these roles that's normally its own wrap-up line, e.g.
"...logged result=clear.") newest-first, without printing the full replay.
"""
import sys, os, json, time, argparse, glob, pwd, datetime

ROLES = ("analyst", "specialist", "tuner-dev", "soclead")

def role_projects_dir(role):
    user = "soc-" + ("tunerdev" if role == "tuner-dev" else role)
    home = pwd.getpwnam(user).pw_dir
    base = os.path.join(home, ".claude", "projects")
    subs = sorted(glob.glob(os.path.join(base, "*")))
    return subs[0] if subs else base            # normally exactly one (per-cwd)

def newest_jsonl(pdir):
    fs = glob.glob(os.path.join(pdir, "*.jsonl"))
    return max(fs, key=os.path.getmtime) if fs else None

def fmt_input(inp):
    if not isinstance(inp, dict):
        return str(inp)[:240]
    for k in ("command", "file_path", "pattern", "path", "url", "description"):
        if k in inp:
            return ("%s=%s" % (k, str(inp[k]).replace("\n", " ")))[:240]
    return json.dumps(inp)[:240]

def render(d, show_thinking):
    t = d.get("type")
    m = d.get("message") if isinstance(d.get("message"), dict) else {}
    c = m.get("content")
    blocks = c if isinstance(c, list) else ([{"type": "text", "text": str(c)}] if c else [])
    out = []
    for b in blocks:
        if not isinstance(b, dict):
            continue
        bt = b.get("type")
        if bt == "text" and b.get("text", "").strip():
            tag = "\033[1;36m🤖 assistant\033[0m" if t == "assistant" else "\033[1;33m👤 user\033[0m"
            out.append("%s: %s" % (tag, b["text"].strip()))
        elif bt == "thinking" and show_thinking and b.get("thinking", "").strip():
            out.append("\033[2m💭 %s\033[0m" % b["thinking"].strip()[:2000])
        elif bt == "tool_use":
            out.append("\033[1;32m🔧 %s\033[0m( %s )" % (b.get("name"), fmt_input(b.get("input"))))
        elif bt == "tool_result":
            content = b.get("content")
            if isinstance(content, list):
                txt = " ".join(x.get("text", "") for x in content if isinstance(x, dict))
            else:
                txt = str(content)
            mark = "\033[31m✗\033[0m" if b.get("is_error") else "↳"
            out.append("   %s %s" % (mark, txt.replace("\n", " ").strip()[:400]))
    return out

def emit(records, show_thinking):
    for d in records:
        for line in render(d, show_thinking):
            print(line)

def load(path):
    recs = []
    with open(path) as f:
        for line in f:
            line = line.strip()
            if line:
                try:
                    recs.append(json.loads(line))
                except Exception:
                    pass
    return recs

def fmt_ts(ts):
    """Claude Code timestamps are ISO 8601 UTC with a trailing 'Z'. Reformat
    to a compact same-shape string for the list view; fall back to the raw
    value (or '?') if it doesn't parse -- a listing tool must never crash on
    one odd record."""
    if not ts:
        return "?"
    try:
        return datetime.datetime.fromisoformat(ts.replace("Z", "+00:00")).strftime("%Y-%m-%dT%H:%M:%SZ")
    except Exception:
        return ts

def session_summary(path):
    """One session's list-view metadata: id, start/end timestamp, turn
    count, and a preview. The preview is the LAST assistant text block in
    the transcript -- for these role prompts that's normally the model's
    own concluding line (e.g. "...logged result=clear to agent-logs/..."),
    which in practice is a better at-a-glance summary than the generic
    'ai-title' record Claude Code also writes (observed to be near-identical
    boilerplate like "Begin scheduled system run" across every session,
    since every role prompt opens the same way)."""
    sid = os.path.basename(path)[:-len(".jsonl")]
    start_ts = end_ts = None
    n = 0
    preview = ""
    try:
        with open(path) as f:
            for line in f:
                line = line.strip()
                if not line:
                    continue
                try:
                    d = json.loads(line)
                except Exception:
                    continue
                ts = d.get("timestamp")
                if ts:
                    if start_ts is None:
                        start_ts = ts
                    end_ts = ts
                if d.get("type") in ("user", "assistant"):
                    n += 1
                if d.get("type") == "assistant":
                    m = d.get("message") if isinstance(d.get("message"), dict) else {}
                    c = m.get("content")
                    if isinstance(c, list):
                        for b in c:
                            if isinstance(b, dict) and b.get("type") == "text" and b.get("text", "").strip():
                                preview = b["text"].strip()
    except Exception:
        pass
    mtime = os.path.getmtime(path) if os.path.exists(path) else 0
    return {
        "id": sid, "path": path, "mtime": mtime,
        "start": start_ts, "end": end_ts, "turns": n,
        "preview": " ".join(preview.split())[-180:],
    }

def list_role_sessions(role):
    pdir = role_projects_dir(role)
    files = sorted(glob.glob(os.path.join(pdir, "*.jsonl")), key=os.path.getmtime, reverse=True)
    print("\033[1m=== %s (%d session%s) ===\033[0m" % (role, len(files), "" if len(files) == 1 else "s"))
    if not files:
        print("  (none)")
        return
    for path in files:
        s = session_summary(path)
        span = "%s -> %s" % (fmt_ts(s["start"]), fmt_ts(s["end"]))
        print("  \033[36m%s\033[0m  %-42s  %3d turns" % (s["id"], span, s["turns"]))
        if s["preview"]:
            print("      %s" % s["preview"])

def main():
    ap = argparse.ArgumentParser()
    ap.add_argument("role", nargs="?", choices=ROLES, help="omit with --list to list every role")
    ap.add_argument("-f", "--follow", action="store_true", help="tail live")
    ap.add_argument("--thinking", action="store_true", help="show model reasoning")
    ap.add_argument("--session", help="specific session uuid (default: newest)")
    ap.add_argument("--list", action="store_true", help="list available sessions (id/time/turns/preview) instead of replaying one")
    a = ap.parse_args()
    if os.geteuid() != 0:
        sys.exit("soc-transcript: transcripts are role-owned 600 -- run with sudo")

    if a.list:
        for role in ([a.role] if a.role else ROLES):
            list_role_sessions(role)
        return

    if not a.role:
        sys.exit("soc-transcript: role is required unless --list is given")

    pdir = role_projects_dir(a.role)
    if a.session:
        name = a.session if a.session.endswith(".jsonl") else a.session + ".jsonl"
        path = os.path.join(pdir, name)
    else:
        path = newest_jsonl(pdir)

    if not a.follow:
        if not path or not os.path.exists(path):
            sys.exit("no transcript found for %s in %s" % (a.role, pdir))
        emit(load(path), a.thinking)
        return

    # follow mode: tail the newest session, roll over when a newer one appears
    cur, pos = path, 0
    sys.stderr.write("# following newest %s session (Ctrl-C to stop)\n" % a.role)
    while True:
        newest = newest_jsonl(pdir)
        if newest and newest != cur:
            cur, pos = newest, 0
            print("\n\033[1m# --- session %s ---\033[0m" % os.path.basename(cur))
        if cur and os.path.exists(cur):
            with open(cur) as f:
                f.seek(pos)
                chunk = f.read()
                pos = f.tell()
            recs = []
            for line in chunk.splitlines():
                line = line.strip()
                if line:
                    try:
                        recs.append(json.loads(line))
                    except Exception:
                        pass
            emit(recs, a.thinking)
        time.sleep(1)

if __name__ == "__main__":
    try:
        main()
    except KeyboardInterrupt:
        pass
