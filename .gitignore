# Secrets — never committed. Add your own ground-truth/unsanitized-config
# filenames here too if you keep any outside soc_context/ (see
# soc-structure/runner-and-permissions.md §3's lockdown pattern).
soc_context/*unsanitized*
soc_context/*_backup.xml

# Notification rate-limit counters (runtime state, not source)
.notify-count/

# Watchdog rate-limit state (runtime state, not source)
.watchdog-state/

# context-balloon-scan checkpoint state (runtime state, not source)
.context-scan-state/

# soc-escalate checkpoint/pattern state + the shared periodic-run gate (runtime state, not source)
.escalation-state/

# Permission-audit logs (runtime; role-owned 600 + chattr +a append-only — not source)
permission-audit/

# Agent-run logs (runtime; role-owned 0640 — not source. Don't track
# these: an operator-side git-tracked edit resets group ownership away
# from socroles, breaking a role's own appends — same "git operations run
# as plain user strip role ownership" class as permission-audit/ above.)
agent-logs/*.log

# Transcript-digest weekly output (runtime; soc-infra:socroles 640,
# regenerated by scripts/transcript-digest before every soclead weekly
# run — same "git-mediated edit strips role-group ownership" risk as
# agent-logs/*.log above, and the same not-source reasoning: it's
# derived data, not something to review as a diff).
agent-logs/transcript-digest-weekly.md

# Notify-body / scratch scratch files a role stages before soc-notify
# (runtime, role-owned — not source; keep these from leaking into git
# tracking).
ticketing-system/*/notify-body-*.txt
ticketing-system/*/notify-ticket-assign-body.txt
ticketing-system/*/scratch-*.json

# Kill switch flag (runtime state, not source)
PAUSED

# Python bytecode cache from running the scripts/ tools directly
__pycache__/
*.pyc
