[Unit]
Description=LLM-based SOC - Agent Watchdog Timer

[Timer]
# Every ~5 min -- must not lag the crons it watches, so RandomizedDelaySec
# is kept small (unlike the minutes-wide jitter on the role timers
# themselves).
OnCalendar=*-*-* *:0/5:00
RandomizedDelaySec=20s
Persistent=true

[Install]
WantedBy=timers.target
